---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Yukti — token-saving Claude Code plugin',
  description = 'A lightweight Claude Code plugin that routes work to the right model per stage. Honest savings: ~50–60% cost reduction vs always-Opus, quality preserved on routine code work.',
  canonical,
} = Astro.props;

// Compose URLs so subpath deploys (e.g. github.com/akii09/yukti/) keep their
// base prefix instead of having `new URL()` strip it.
const siteUrl = (Astro.site?.toString() ?? 'https://yukti.pages.dev/').replace(/\/+$/, '');
const pathname = Astro.url.pathname.startsWith('/') ? Astro.url.pathname : `/${Astro.url.pathname}`;
const pageUrl = canonical ?? `${siteUrl}${pathname}`;
const ogImage = `${siteUrl}/favicon.svg`;

// Structured data — SoftwareApplication
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Yukti',
  description,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, Linux, Windows',
  url: 'https://github.com/akii09/yukti',
  author: {
    '@type': 'Person',
    name: 'akii09',
    url: 'https://github.com/akii09',
  },
  license: 'https://opensource.org/licenses/MIT',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#fafaf9" />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Yukti" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts: load only the weights we use, with display swap -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

    <slot name="head" />
  </head>
  <body data-animate-logo="true">
    <a href="#main" class="skip-link">Skip to content</a>

    <slot />
  </body>
</html>
