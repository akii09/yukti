---
const want = [
  'Real benchmark data — including unflattering numbers',
  'Bug reports with a reproducer and a verification step',
  'Verification-command presets for non-JS projects (Elixir, Java, Ruby, …)',
  'Documentation fixes — typos, broken links, install steps',
];
---

<section class="contrib" id="contribute" aria-labelledby="contrib-h">
  <div class="container">
    <span class="eyebrow" data-reveal>Contribute</span>
    <h2 id="contrib-h" data-reveal>What helps Yukti most.</h2>

    <div class="contrib-card" data-reveal>
      <ul class="want-list">
        {want.map((item) => (
          <li>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M5 13 L 10 18 L 20 6" stroke="var(--accent-ink)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>

      <div class="contrib-cta">
        <a class="btn" href="https://github.com/akii09/yukti/issues/new?template=benchmark.md" target="_blank" rel="noopener">
          Submit a benchmark
        </a>
        <a class="btn btn--ghost" href="https://github.com/akii09/yukti/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener">
          Contribution guide →
        </a>
      </div>
    </div>

    <p class="contrib-foot" data-reveal>
      For what we don't accept (out-of-scope features, undocumented-internals bets, marketing claims we can't demonstrate), see <a href="https://github.com/akii09/yukti/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener">CONTRIBUTING.md</a>.
    </p>
  </div>
</section>

<style>
  .contrib { background: var(--paper-2); }

  .contrib-card {
    background: var(--paper);
    border: 1.5px solid var(--accent);
    border-radius: var(--radius-lg);
    padding: 1.75rem 1.6rem 1.6rem;
    margin: 2.5rem 0 1.5rem;
    box-shadow: 4px 4px 0 var(--accent-soft);
    max-width: 720px;
  }

  .want-list {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .want-list li {
    display: flex;
    gap: 0.75rem;
    color: var(--ink-soft);
    font-size: 1rem;
    line-height: 1.55;
  }
  .want-list li svg {
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .contrib-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .contrib-foot {
    color: var(--grey);
    font-size: 0.9rem;
    margin: 0;
    max-width: 64ch;
  }
  .contrib-foot a { color: var(--grey); text-decoration: underline wavy var(--accent-soft); text-underline-offset: 3px; }
  .contrib-foot a:hover { color: var(--ink); }
</style>
