---
const tabs = [
  {
    id: 'install-marketplace',
    label: 'Marketplace',
    pill: 'recommended',
    cmds: [
      '/plugin marketplace add akii09/yukti',
      '/plugin install yukti@akii09-yukti',
    ],
    note: 'Run inside any Claude Code session. Installs once at the user level — available across every project. Skills are namespaced (/yukti:smart, /yukti:status, /yukti:plan, /yukti:review).',
  },
  {
    id: 'install-curl',
    label: 'Per-project',
    pill: null,
    cmds: ['curl -sSL https://raw.githubusercontent.com/akii09/yukti/main/install.sh | bash'],
    note: 'For locked-down environments without marketplace access, or when you want Yukti pinned in one specific repo. Skills are NOT namespaced in this mode (e.g. /smart instead of /yukti:smart).',
  },
];

const examples = [
  { input: '/yukti:smart Add a CSV export to the schedule page', kind: 'code change', goes: 'full pipeline: explore → plan → confirm → implement → review' },
  { input: '/yukti:smart Compare these two plans, which is current?', kind: 'analysis', goes: 'answered directly in your current session' },
  { input: '/yukti:plan Migrate moment → date-fns', kind: 'plan only', goes: 'forwarded to the planner (Opus)' },
  { input: '/yukti:status', kind: 'project brief', goes: 'branch, uncommitted changes, in-flight task; savings if telemetry is on' },
];
---

<section class="get-started" id="get-started" aria-labelledby="gs-h">
  <div class="container">
    <span class="eyebrow" data-reveal>Get started</span>
    <h2 id="gs-h" data-reveal>Two install paths. Pick one.</h2>

    <div class="install-tabs" data-reveal role="region" aria-label="Installation method">
      {/* Radios live as direct siblings of .tab-labels and .tab-panels so the
          CSS general-sibling selector (~) can flip the active tab without JS.
          See web/CLAUDE.md "Astro scoping gotcha" for the comma-grouping rule. */}
      {tabs.map((t, i) => (
        <input
          type="radio"
          name="install-tab"
          id={t.id}
          class="tab-radio"
          checked={i === 0 ? true : undefined}
          aria-label={t.label}
        />
      ))}

      <div class="tab-labels" role="tablist" aria-label="Installation method">
        {tabs.map((t) => (
          <label for={t.id} class="tab-label" role="tab">
            <span class="tab-label-text">{t.label}</span>
            {t.pill && <span class="tab-pill">{t.pill}</span>}
          </label>
        ))}
      </div>

      <div class="tab-panels">
        {tabs.map((t) => (
          <div class={`tab-panel tab-panel--${t.id}`} role="tabpanel" aria-labelledby={t.id}>
            <div class="code-block">
              <pre><code>{t.cmds.join('\n')}</code></pre>
              <button class="copy-btn" type="button" aria-label={`Copy ${t.label} install command`}>
                <svg class="copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <rect x="8" y="8" width="12" height="14" rx="2" stroke="currentColor" stroke-width="2"/>
                  <path d="M16 6 V 4 a 2 2 0 0 0 -2 -2 H 6 a 2 2 0 0 0 -2 2 v 12 a 2 2 0 0 0 2 2 h 2" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <svg class="check-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M5 12 L 10 17 L 20 7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="copy-text">Copy</span>
              </button>
            </div>
            <p class="tab-note">{t.note}</p>
          </div>
        ))}
      </div>
    </div>

    <h3 class="usage-h" data-reveal>What you can type</h3>

    <ul class="examples" data-reveal>
      {examples.map((ex) => (
        <li class="example">
          <code class="example-input">{ex.input}</code>
          <div class="example-arrow" aria-hidden="true">
            <svg width="32" height="14" viewBox="0 0 32 14" fill="none">
              <path d="M 2 7 Q 8 3, 16 7 T 28 7 M 22 3 L 28 7 L 22 11" stroke="var(--grey)" stroke-width="1.5" stroke-linecap="round" fill="none" />
            </svg>
          </div>
          <div class="example-result">
            <span class="example-kind">{ex.kind}</span>
            <span class="example-goes">{ex.goes}</span>
          </div>
        </li>
      ))}
    </ul>

    <p class="dev-note" data-reveal>
      Building / hacking on Yukti? See the <a href="https://github.com/akii09/yukti#plugin-development" target="_blank" rel="noopener">plugin-development setup</a> in the README.
    </p>
  </div>
</section>

<style>
  .get-started { background: var(--paper); }

  /* === Tabs (CSS-only via radio inputs) === */
  .install-tabs {
    margin: 2rem 0 3rem;
    position: relative;
  }

  /* Hide the radios themselves but keep them in normal flow position so
     focus rings can be shown via :focus-visible on the paired label. */
  .tab-radio {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
    top: 0;
    left: 0;
    margin: 0;
  }

  .tab-labels {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    border-bottom: 1.5px solid var(--grey-line);
    margin-bottom: 0;
    padding: 0;
  }

  .tab-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.05rem;
    border: 1.5px solid transparent;
    border-bottom: 0;
    border-radius: var(--radius-sm) var(--radius-sm) 0 0;
    background: transparent;
    color: var(--grey);
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: color 0.18s ease, background 0.18s ease, border-color 0.18s ease, transform 0.12s ease;
    margin-bottom: -1.5px;
    user-select: none;
    position: relative;
  }
  .tab-label:hover {
    color: var(--ink);
    background: var(--paper-2);
  }
  .tab-label:active { transform: translateY(1px); }

  .tab-pill {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent-ink);
    background: var(--accent-soft);
    padding: 0.14rem 0.5rem;
    border-radius: 999px;
    line-height: 1.4;
  }

  /* All panels hidden by default */
  .tab-panel { display: none; }

  .tab-panels {
    background: var(--paper-2);
    border: 1.5px solid var(--grey-line);
    border-top-color: transparent;
    border-radius: 0 var(--radius) var(--radius) var(--radius);
    padding: 1.4rem 1.4rem 1.5rem;
  }

  /* Active state — split into one ruleset per ID to avoid Astro CSS scoper
     bug that drops the leading `#id:checked ~` from the FIRST selector when
     comma-grouping. See web/CLAUDE.md "Astro scoping gotcha". */

  #install-marketplace:checked ~ .tab-labels label[for="install-marketplace"] {
    color: var(--ink);
    background: var(--paper-2);
    border-color: var(--grey-line);
    border-bottom-color: var(--paper-2);
  }
  #install-curl:checked ~ .tab-labels label[for="install-curl"] {
    color: var(--ink);
    background: var(--paper-2);
    border-color: var(--grey-line);
    border-bottom-color: var(--paper-2);
  }

  #install-marketplace:checked ~ .tab-panels .tab-panel--install-marketplace {
    display: block;
  }
  #install-curl:checked ~ .tab-panels .tab-panel--install-curl {
    display: block;
  }

  /* Keyboard focus ring on the paired label */
  #install-marketplace:focus-visible ~ .tab-labels label[for="install-marketplace"] {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  #install-curl:focus-visible ~ .tab-labels label[for="install-curl"] {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* === Code block with copy button === */
  .code-block {
    position: relative;
    margin: 0 0 1rem;
  }
  .code-block pre {
    margin: 0;
    font-size: 0.92rem;
    padding: 0.95rem 1.1rem;
    padding-right: 5.5rem; /* leave room for the copy button */
  }
  /* Floating "chip" button — paper-colored on dark pre for clear visibility.
     No translucent whites; explicit colors so currentColor / opacity quirks
     don't cause a "where's the button?" moment. */
  .copy-btn {
    position: absolute;
    top: 0.55rem;
    right: 0.55rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.75rem;
    background: var(--paper);
    color: var(--ink);
    border: 1.5px solid var(--paper);
    border-radius: 6px;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease, transform 0.08s ease;
    line-height: 1;
    z-index: 2;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.05);
  }
  .copy-btn:hover {
    background: var(--accent-soft);
    border-color: var(--accent);
    color: var(--accent-ink);
  }
  .copy-btn:active {
    transform: translateY(1px);
  }
  .copy-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .copy-btn .copy-icon,
  .copy-btn .check-icon {
    color: var(--ink);
    flex-shrink: 0;
  }
  .copy-btn .check-icon { display: none; }
  /* "Copied" state — accent background, clear win signal */
  .copy-btn.is-copied {
    background: var(--accent);
    color: var(--paper);
    border-color: var(--accent);
  }
  .copy-btn.is-copied .copy-icon { display: none; }
  .copy-btn.is-copied .check-icon { display: inline-block; color: var(--paper); }
  .copy-btn.is-copied:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--paper);
  }

  .tab-note {
    color: var(--ink-soft);
    font-size: 0.94rem;
    line-height: 1.6;
    margin: 0;
    max-width: 64ch;
  }

  /* === Usage examples === */
  .usage-h {
    margin: 0 0 1.25rem;
    font-size: clamp(1.5rem, 2.6vw, 1.9rem);
  }

  .examples {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .example {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) auto minmax(0, 2fr);
    gap: 0.85rem;
    align-items: center;
    background: var(--paper-2);
    border: 1px solid var(--grey-line);
    border-radius: var(--radius);
    padding: 0.8rem 1rem;
  }
  .example-input {
    font-family: var(--font-mono);
    font-size: 0.86rem;
    background: transparent;
    border: 0;
    padding: 0;
    color: var(--ink);
    overflow-x: auto;
    word-break: break-word;
  }
  .example-arrow svg { flex-shrink: 0; }
  .example-result {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .example-kind {
    font-family: var(--font-display);
    color: var(--accent-ink);
    font-size: 1.1rem;
    line-height: 1;
  }
  .example-goes {
    color: var(--grey);
    font-size: 0.86rem;
  }

  .dev-note {
    margin: 2rem 0 0;
    color: var(--grey);
    font-size: 0.9rem;
  }
  .dev-note a {
    color: var(--accent-ink);
  }

  @media (max-width: 640px) {
    .example {
      grid-template-columns: 1fr;
      text-align: left;
    }
    .example-arrow { display: none; }
    .tab-label { font-size: 0.88rem; padding: 0.55rem 0.85rem; }
    .tab-pill { font-size: 0.62rem; padding: 0.1rem 0.4rem; }
    .tab-panels { padding: 1.1rem 1.1rem 1.2rem; }
    .code-block pre { padding-right: 4.2rem; font-size: 0.84rem; }
    .copy-btn { padding: 0.28rem 0.5rem; font-size: 0.74rem; }
    .copy-btn .copy-text { display: none; } /* icon-only on mobile */
  }
</style>

<script>
  // Copy-to-clipboard for the install command code blocks.
  // One handler for all `.copy-btn` buttons. No external deps.
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async (ev) => {
      ev.preventDefault();
      const codeEl = btn.parentElement?.querySelector('pre code');
      const text = codeEl?.textContent?.trim() ?? '';
      if (!text) return;

      let copied = false;
      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(text);
          copied = true;
        } else {
          throw new Error('clipboard API unavailable');
        }
      } catch {
        // Fallback for older browsers / non-secure contexts (e.g. file://).
        try {
          const ta = document.createElement('textarea');
          ta.value = text;
          ta.style.cssText = 'position:fixed;left:-9999px;top:0;opacity:0;';
          document.body.appendChild(ta);
          ta.focus();
          ta.select();
          copied = document.execCommand('copy');
          document.body.removeChild(ta);
        } catch {
          copied = false;
        }
      }

      if (!copied) return;

      btn.classList.add('is-copied');
      const label = btn.querySelector('.copy-text');
      const original = label?.textContent ?? 'Copy';
      if (label) label.textContent = 'Copied';
      setTimeout(() => {
        btn.classList.remove('is-copied');
        if (label) label.textContent = original;
      }, 1600);
    });
  });
</script>
