---
const claims = [
  {
    headline: 'Designed to reduce cost on routine work',
    body: 'Each pipeline stage runs on the cheapest model that does the step well — Haiku for exploration, Sonnet for implementation, Opus for planning and review. Numbers in the benchmarks section are illustrative; real measurement is in progress (v0.2.0 ships opt-in local telemetry).',
    icon: 'savings',
  },
  {
    headline: 'Quality on par for routine work',
    body: 'Sonnet handles focused, single-phase implementation tasks at near-Opus quality. The trick is keeping the focus tight — the implementer subagent has no Grep or Glob tool, so it can\'t wander. Files are pre-resolved by the planner.',
    icon: 'quality',
  },
  {
    headline: 'No rules to memorize',
    body: 'Just type /yukti:smart with any request. Code change? Routes through the full pipeline. Analysis question? Answered directly in your current session — no extra wait. The skill classifies and acts. It never refuses you.',
    icon: 'route',
  },
  {
    headline: 'Hard gates where they matter',
    body: 'After the planner produces a plan, the orchestrator stops and asks you to approve. That is the single highest-leverage quality gate in the system. The user-confirmation step cannot be skipped.',
    icon: 'gate',
  },
  {
    headline: 'Knows your project state',
    body: 'On every Claude Code session start, Yukti shows a short brief: branch, uncommitted changes, recent commits, your last in-flight Yukti task, and which memory mechanisms are active. Complements the auto-loaded CLAUDE.md and built-in auto memory — never duplicates them.',
    icon: 'brief',
  },
  {
    headline: 'Local-only savings dashboard, opt-in',
    body: 'Set "telemetry": "local" in yukti-config.json and Yukti logs per-task cost data to a file in your home directory. Run /yukti:status to see your cumulative savings (last 30 days, by task class). Default off; never uploaded.',
    icon: 'chart',
  },
];

function iconPath(name: string) {
  switch (name) {
    case 'savings':
      return 'M 8 26 C 12 10, 28 6, 36 18 M 36 18 L 30 16 M 36 18 L 34 24';
    case 'quality':
      return 'M 8 22 L 16 30 L 36 12';
    case 'route':
      return 'M 6 22 L 18 22 L 22 12 L 28 32 L 32 22 L 42 22';
    case 'gate':
      return 'M 10 18 L 22 12 L 34 18 M 10 18 L 10 30 L 22 36 L 34 30 L 34 18 M 22 12 L 22 36';
    case 'brief':
      // Document with header line + body lines (project brief)
      return 'M 10 8 L 30 8 L 30 36 L 10 36 Z M 14 14 L 26 14 M 14 20 L 26 20 M 14 26 L 22 26 M 14 32 L 24 32';
    case 'chart':
      // Three rising bars (savings dashboard)
      return 'M 8 32 L 14 32 L 14 24 L 8 24 Z M 18 32 L 24 32 L 24 16 L 18 16 Z M 28 32 L 34 32 L 34 20 L 28 20 Z M 6 36 L 36 36';
    default:
      return '';
  }
}
---

<section class="why" id="why" aria-labelledby="why-h">
  <div class="container">
    <span class="eyebrow" data-reveal>Why use Yukti</span>
    <h2 id="why-h" data-reveal>Honest claims, not marketing copy.</h2>

    <div class="why-grid">
      {claims.map((c, i) => (
        <article class="claim" data-reveal style={`--delay: ${i * 80}ms`}>
          <span class="claim-icon" aria-hidden="true">
            <svg viewBox="0 0 44 44" width="36" height="36" fill="none">
              <path
                d={iconPath(c.icon)}
                stroke="var(--accent-ink)"
                stroke-width="2.4"
                stroke-linecap="round"
                stroke-linejoin="round"
                fill="none"
              />
            </svg>
          </span>
          <h3>{c.headline}</h3>
          <p>{c.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .why { background: var(--paper-2); }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .claim {
    background: var(--paper);
    border: 1.5px solid var(--grey-line);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.4rem;
    position: relative;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    transition-delay: var(--delay, 0ms);
  }
  .claim:hover {
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 var(--ink);
    border-color: var(--ink);
  }

  .claim-icon {
    display: inline-flex;
    width: 56px;
    height: 56px;
    align-items: center;
    justify-content: center;
    background: var(--paper-2);
    border: 1.5px solid var(--accent-soft);
    border-radius: 14px;
    margin-bottom: 1rem;
  }
  .claim-icon svg { overflow: visible; }

  .claim h3 {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1.05rem;
    margin: 0 0 0.5rem;
    color: var(--ink);
    line-height: 1.3;
  }

  .claim p {
    color: var(--ink-soft);
    font-size: 0.96rem;
    line-height: 1.6;
    margin: 0;
  }

  /* Stagger reveal — uses --delay set inline */
  [data-reveal] {
    transition-delay: var(--delay, 0ms);
  }
</style>
