---
const claims = [
  {
    headline: 'Real cost savings, with receipts',
    body: 'Routing each pipeline stage to the right model (Haiku for exploration, Sonnet for implementation, Opus for planning + review) cuts cost by ~50–60% vs. always-Opus on routine code work. We publish honest benchmarks below — including cases where Yukti barely helps.',
    icon: 'savings',
  },
  {
    headline: 'Quality on par for routine work',
    body: 'Sonnet handles focused, single-phase implementation tasks at near-Opus quality. The trick is keeping the focus tight — the implementer subagent has no Grep or Glob tool, so it can\'t wander. Files are pre-resolved by the planner.',
    icon: 'quality',
  },
  {
    headline: 'No rules to memorize',
    body: 'Just type /yukti:smart with any request. Code change? Routes through the full pipeline. Analysis question? Answered directly in your current session — no extra wait. The skill classifies and acts. It never refuses you.',
    icon: 'route',
  },
  {
    headline: 'Hard gates where they matter',
    body: 'After the planner produces a plan, the orchestrator stops and asks you to approve. That\'s the single highest-leverage quality gate in the system. The user-confirmation step cannot be skipped.',
    icon: 'gate',
  },
  {
    headline: 'No undocumented bets',
    body: 'Yukti deliberately avoids features whose behavior depends on undocumented Claude Code internals. No silent auto-routing, no hard Stop-hook gates, no MCP search server. If we can\'t verify a feature against the docs, it doesn\'t ship in v1.',
    icon: 'docs',
  },
  {
    headline: 'Honest about its limits',
    body: 'Yukti shines on adding/refactoring/fixing in well-organized code. It\'s weaker on gnarly novel debugging where most of the work is Opus reasoning anyway. The README and this site say so plainly. We will not lie about benchmarks.',
    icon: 'honest',
  },
];

function iconPath(name: string) {
  switch (name) {
    case 'savings':
      return 'M 8 26 C 12 10, 28 6, 36 18 M 36 18 L 30 16 M 36 18 L 34 24';
    case 'quality':
      return 'M 8 22 L 16 30 L 36 12';
    case 'route':
      return 'M 6 22 L 18 22 L 22 12 L 28 32 L 32 22 L 42 22';
    case 'gate':
      return 'M 10 18 L 22 12 L 34 18 M 10 18 L 10 30 L 22 36 L 34 30 L 34 18 M 22 12 L 22 36';
    case 'docs':
      return 'M 12 8 L 32 8 L 32 36 L 12 36 Z M 16 16 L 28 16 M 16 22 L 28 22 M 16 28 L 24 28';
    case 'honest':
      return 'M 22 6 C 30 14, 30 22, 22 30 C 14 22, 14 14, 22 6 Z M 22 14 L 22 24';
    default:
      return '';
  }
}
---

<section class="why" id="why" aria-labelledby="why-h">
  <div class="container">
    <span class="eyebrow" data-reveal>Why use Yukti</span>
    <h2 id="why-h" data-reveal>Honest claims, not marketing copy.</h2>

    <div class="why-grid">
      {claims.map((c, i) => (
        <article class="claim" data-reveal style={`--delay: ${i * 80}ms`}>
          <span class="claim-icon" aria-hidden="true">
            <svg viewBox="0 0 44 44" width="36" height="36" fill="none">
              <path
                d={iconPath(c.icon)}
                stroke="var(--accent-ink)"
                stroke-width="2.4"
                stroke-linecap="round"
                stroke-linejoin="round"
                fill="none"
              />
            </svg>
          </span>
          <h3>{c.headline}</h3>
          <p>{c.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .why { background: var(--paper-2); }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .claim {
    background: var(--paper);
    border: 1.5px solid var(--grey-line);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.4rem;
    position: relative;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    transition-delay: var(--delay, 0ms);
  }
  .claim:hover {
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 var(--ink);
    border-color: var(--ink);
  }

  .claim-icon {
    display: inline-flex;
    width: 56px;
    height: 56px;
    align-items: center;
    justify-content: center;
    background: var(--paper-2);
    border: 1.5px solid var(--accent-soft);
    border-radius: 14px;
    margin-bottom: 1rem;
  }
  .claim-icon svg { overflow: visible; }

  .claim h3 {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1.05rem;
    margin: 0 0 0.5rem;
    color: var(--ink);
    line-height: 1.3;
  }

  .claim p {
    color: var(--ink-soft);
    font-size: 0.96rem;
    line-height: 1.6;
    margin: 0;
  }

  /* Stagger reveal — uses --delay set inline */
  [data-reveal] {
    transition-delay: var(--delay, 0ms);
  }
</style>
