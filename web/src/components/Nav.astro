---
import Logo from './Logo.astro';

const links = [
  { href: '#what-it-does', label: 'What it does' },
  { href: '#why', label: 'Why' },
  { href: '#get-started', label: 'Get started' },
  { href: '#benchmarks', label: 'Benchmarks' },
  { href: '#story', label: 'The story' },
];
---

<header class="nav-wrap">
  <nav class="nav" aria-label="Primary">
    <a href="#" class="nav-brand" aria-label="Yukti home">
      <Logo size={28} withWordmark={true} />
    </a>

    <ul class="nav-links">
      {links.map(({ href, label }) => (
        <li><a href={href}>{label}</a></li>
      ))}
    </ul>

    <a href="https://github.com/akii09/yukti" class="nav-cta" target="_blank" rel="noopener">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.4 3.6 1 .1-.8.4-1.4.8-1.7-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.3-3.2-.1-.3-.6-1.5.1-3.2 0 0 1-.3 3.4 1.2a11.6 11.6 0 0 1 6.2 0c2.4-1.6 3.4-1.2 3.4-1.2.7 1.7.2 2.9.1 3.2.8.8 1.3 2 1.3 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3"/>
      </svg>
      <span>GitHub</span>
    </a>
  </nav>
</header>

<style>
  .nav-wrap {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    background: rgba(250, 250, 249, 0.78);
    border-bottom: 1px solid var(--grey-line);
  }

  .nav {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-brand {
    color: var(--ink);
    text-decoration: none;
    flex-shrink: 0;
  }
  .nav-brand:hover { text-decoration: none; }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
    justify-content: center;
  }
  .nav-links a {
    color: var(--grey);
    font-size: 0.94rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover {
    color: var(--ink);
    text-decoration: underline wavy var(--accent);
    text-underline-offset: 5px;
    text-decoration-thickness: 1.5px;
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.9rem;
    border: 1.5px solid var(--ink);
    border-radius: var(--radius-sm);
    color: var(--ink);
    font-size: 0.88rem;
    font-weight: 600;
    transition: all 0.18s;
  }
  .nav-cta:hover {
    background: var(--ink);
    color: var(--paper);
    text-decoration: none;
  }

  @media (max-width: 720px) {
    .nav-links { display: none; }
    .nav { padding: 0.65rem 1rem; }
  }
</style>
