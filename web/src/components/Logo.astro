---
// Hand-drawn Y where the descender splits into 3 branches.
// Branches represent the model split (Haiku / Sonnet / Opus).
// Path data uses tiny irregular cubic bezier curves to feel sketched, not vector-perfect.

interface Props {
  size?: number;
  withWordmark?: boolean;
  ariaLabel?: string;
}

const { size = 32, withWordmark = false, ariaLabel = 'Yukti' } = Astro.props;
---

<span class="logo" style={`--logo-size: ${size}px;`}>
  <svg
    width={size}
    height={size}
    viewBox="0 0 64 64"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label={ariaLabel}
    class="logo-mark"
  >
    <!-- Y top-left stroke (slight wobble) -->
    <path
      d="M 14 12 C 16 13, 22 22, 26 28 C 28 31, 30 33, 32 34"
      stroke="currentColor"
      stroke-width="3.4"
      stroke-linecap="round"
      stroke-linejoin="round"
      fill="none"
      class="logo-path logo-y-left"
    />
    <!-- Y top-right stroke -->
    <path
      d="M 50 12 C 48 13, 42 22, 38 28 C 36 31, 34 33, 32 34"
      stroke="currentColor"
      stroke-width="3.4"
      stroke-linecap="round"
      stroke-linejoin="round"
      fill="none"
      class="logo-path logo-y-right"
    />
    <!-- Stem from junction down to split point -->
    <path
      d="M 32 34 C 32.3 38, 31.8 42, 32 46"
      stroke="currentColor"
      stroke-width="3.4"
      stroke-linecap="round"
      stroke-linejoin="round"
      fill="none"
      class="logo-path logo-stem"
    />
    <!-- Three branches from split point -->
    <path
      d="M 32 46 C 28 49, 24 51, 20 54"
      stroke="currentColor"
      stroke-width="2.6"
      stroke-linecap="round"
      fill="none"
      class="logo-path logo-branch logo-branch-1"
    />
    <path
      d="M 32 46 C 32.2 49, 31.9 52, 32 56"
      stroke="currentColor"
      stroke-width="2.6"
      stroke-linecap="round"
      fill="none"
      class="logo-path logo-branch logo-branch-2"
    />
    <path
      d="M 32 46 C 36 49, 40 51, 44 54"
      stroke="currentColor"
      stroke-width="2.6"
      stroke-linecap="round"
      fill="none"
      class="logo-path logo-branch logo-branch-3"
    />
    <!-- Three model dots -->
    <circle cx="20" cy="54" r="2.2" fill="var(--accent, currentColor)" class="logo-dot logo-dot-1" />
    <circle cx="32" cy="56" r="2.2" fill="var(--accent, currentColor)" class="logo-dot logo-dot-2" />
    <circle cx="44" cy="54" r="2.2" fill="var(--accent, currentColor)" class="logo-dot logo-dot-3" />
  </svg>

  {withWordmark && <span class="logo-text">Yukti</span>}
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--ink, #1f1f1f);
    line-height: 1;
  }

  .logo-mark {
    flex-shrink: 0;
    overflow: visible;
  }

  .logo-text {
    font-family: 'Caveat', 'Patrick Hand', cursive;
    font-size: calc(var(--logo-size, 32px) * 0.95);
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  /* Subtle entrance: dots pop after stroke draws (when --animate-logo is set) */
  .logo-path {
    stroke-dasharray: 100;
    stroke-dashoffset: 0;
  }

  :global([data-animate-logo='true']) .logo-path {
    stroke-dashoffset: 100;
    animation: logoDraw 0.9s ease-out forwards;
  }
  :global([data-animate-logo='true']) .logo-y-left { animation-delay: 0s; }
  :global([data-animate-logo='true']) .logo-y-right { animation-delay: 0.1s; }
  :global([data-animate-logo='true']) .logo-stem { animation-delay: 0.4s; }
  :global([data-animate-logo='true']) .logo-branch-1 { animation-delay: 0.55s; }
  :global([data-animate-logo='true']) .logo-branch-2 { animation-delay: 0.6s; }
  :global([data-animate-logo='true']) .logo-branch-3 { animation-delay: 0.65s; }

  :global([data-animate-logo='true']) .logo-dot {
    opacity: 0;
    transform-origin: center;
    transform: scale(0.4);
    animation: logoDotPop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
  :global([data-animate-logo='true']) .logo-dot-1 { animation-delay: 1.05s; }
  :global([data-animate-logo='true']) .logo-dot-2 { animation-delay: 1.15s; }
  :global([data-animate-logo='true']) .logo-dot-3 { animation-delay: 1.25s; }

  @keyframes logoDraw {
    to { stroke-dashoffset: 0; }
  }

  @keyframes logoDotPop {
    to { opacity: 1; transform: scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    :global([data-animate-logo='true']) .logo-path,
    :global([data-animate-logo='true']) .logo-dot {
      animation: none;
      opacity: 1;
      transform: none;
      stroke-dashoffset: 0;
    }
  }
</style>
