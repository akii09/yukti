---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import GetStarted from '../components/GetStarted.astro';
import Pipeline from '../components/Pipeline.astro';
import WhyUse from '../components/WhyUse.astro';
import PlaysWellWith from '../components/PlaysWellWith.astro';
import Contribute from '../components/Contribute.astro';
import Footer from '../components/Footer.astro';

// Hidden until we have measured numbers from real telemetry.
// The component file remains in src/components/Benchmarks.astro for when we re-enable.
// import Benchmarks from '../components/Benchmarks.astro';

// Removed for now — premature changelog before users have shipped on releases.
// File kept at src/components/Story.astro in case we want to revive it later.
// import Story from '../components/Story.astro';
---

<BaseLayout
  title="Yukti — Claude Code plugin that routes work to the right model per stage"
  description="Yukti routes each Claude Code pipeline stage to the cheapest model that does the step well — Haiku to explore, Sonnet to implement, Opus to plan and review. Composes with built-in CLAUDE.md, auto memory, and adjacent plugins."
>
  <Nav />
  <main id="main">
    <Hero />
    <hr class="section-divider" aria-hidden="true" />
    <GetStarted />
    <Pipeline />
    <WhyUse />
    <hr class="section-divider" aria-hidden="true" />
    <PlaysWellWith />
    <Contribute />
  </main>
  <Footer />
</BaseLayout>

<script>
  // Scroll-triggered reveal — uses IntersectionObserver (zero deps, ~1KB).
  const supportsIO = 'IntersectionObserver' in window;

  if (supportsIO) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.15, rootMargin: '0px 0px -50px 0px' }
    );

    document.querySelectorAll('[data-reveal], .diagram-wrap').forEach((el) => io.observe(el));
  } else {
    // No IO → just show everything.
    document.querySelectorAll('[data-reveal], .diagram-wrap').forEach((el) =>
      el.classList.add('is-visible')
    );
  }

  // Smooth scroll for anchor links (with header offset)
  document.querySelectorAll('a[href^="#"]').forEach((link) => {
    link.addEventListener('click', (e) => {
      const href = (link as HTMLAnchorElement).getAttribute('href');
      if (!href || href === '#') return;
      const target = document.querySelector(href);
      if (target) {
        e.preventDefault();
        const headerOffset = 70;
        const top = (target as HTMLElement).getBoundingClientRect().top + window.scrollY - headerOffset;
        window.scrollTo({ top, behavior: 'smooth' });
        history.pushState(null, '', href);
      }
    });
  });
</script>
